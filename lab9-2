using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter a string: ");
        string str = Console.ReadLine();

        string reversed = "";

        for (int i = str.Length - 1; i >= 0; i--)
        {
            reversed += str[i];
        }

        if (str == reversed)
            Console.WriteLine("String is Palindrome");
        else
            Console.WriteLine("String is Not Palindrome");
    }
}