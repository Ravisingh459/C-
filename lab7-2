using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter the limit: ");
        int limit = int.Parse(Console.ReadLine());

        int first = 0, second = 1;

        Console.WriteLine("Fibonacci Series:");

        while (first <= limit)
        {
            Console.Write(first + " ");

            int next = first + second;
            first = second;
            second = next;
        }
    }
}